# ─── Database ────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=yourpassword
DB_NAME=crm_db

# ─── JWT ─────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_key_here_min_32_chars
JWT_EXPIRES_IN=7d

# ─── App ─────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS (vergul bilan ajratilgan domenlar) ─────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:5173

# ─── Google OAuth ────────────────────────────────────────────────────
# https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ─── GitHub OAuth ────────────────────────────────────────────────────
# https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback
